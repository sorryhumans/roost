{
  "name": "roost-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Read-only collector + SSE server for Roost, the live 3D office for Claude Code agents.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "node --experimental-strip-types --import ./tools/register-ts-loader.mjs src/cli.ts",
    "start": "node --experimental-strip-types --import ./tools/register-ts-loader.mjs src/server.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "fastify": "^5.8.5"
  },
  "license": "MIT"
}